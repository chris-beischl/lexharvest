[duolingo]
base_url = "https://www.duolingo.com/2017-06-30"
user_id = "123456789"
target_language = "es"   # language being learned
source_language = "de"   # language you already know (UI language)
page_size = 50
payload_file = "duolingo_payload.json"
accept_language = "de-DE,de;q=0.9"

[normalizer]
target_model = "es_core_news_sm"
source_model = "de_core_news_sm"

[llm]
provider = "ollama"              # "ollama" | "openai" | "anthropic"
model = "gemma4:e2b"
# base_url = "http://localhost:11434/v1"   # ollama only; defaults to localhost if omitted

[database]
path = "lexharvest.db"

[export]
output_dir = "exports"
